{
  "name": "coderover",
  "version": "1.1.2",
  "description": "Local bridge between CodeRover and the CodeRover mobile app. Run `coderover up` to start.",
  "main": "dist/index.js",
  "bin": {
    "coderover": "./bin/coderover.js"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "build": "bun ./scripts/default-runtime.mjs build",
    "start": "bun ./scripts/default-runtime.mjs start",
    "test": "bun ./scripts/default-runtime.mjs test"
  },
  "keywords": [
    "coderover",
    "coderover",
    "bridge",
    "cli"
  ],
  "author": "Emanuele Di Pietro",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.74",
    "qrcode-terminal": "^0.12.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.2"
  }
}
