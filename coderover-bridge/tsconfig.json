{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "useUnknownInCatchVariables": false,
    "noEmitOnError": true,
    "esModuleInterop": false,
    "skipLibCheck": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "index.ts",
    "src/**/*.ts",
    "test/**/*.ts",
    "types/**/*.d.ts"
  ]
}
